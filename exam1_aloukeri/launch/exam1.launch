<launch>

  <!-- 1. load parameters from .yaml file (goal_x, goal_y, max_time) -->
  <rosparam file="$(find exam1_aloukeri)/config/params.yaml"
            command="load" ns="/exam1" />

  <!-- 2. Line Follower — first disabled, initialized by server -->
  <node pkg="exam1_aloukeri" type="line_follower.py"
        name="line_follower" output="screen">
    <param name="standalone" value="false"/>
  </node>

  <!-- 3. Action Server -->
  <node pkg="exam1_aloukeri" type="move_server.py"
        name="move_robot_server" output="screen"/>

  <!-- 4. Action Client  -->
  <node pkg="exam1_aloukeri" type="move_client.py"
        name="move_robot_client" output="screen"
        launch-prefix="bash -c 'sleep 2; $0 $@'"/>

  <!-- 5. Rosbag: record of /cmd_vel -->
  <node pkg="rosbag" type="record" name="rosbag_record"
        args="-O $(env HOME)/exam1_bag /cmd_vel"
        output="screen"/>

</launch>
